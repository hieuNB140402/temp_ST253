<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="horizontal">

    <!--        btnTabHome-->
    <LinearLayout
        android:id="@+id/btnTabHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!--            vLineTabHome-->
        <View
            android:id="@+id/vLineTabHome"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginHorizontal="44dp"
            android:background="@color/blue_000D4C" />

        <!--            imvTabHome-->
        <ImageView
            android:id="@+id/imvTabHome"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginVertical="14dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_home" />
    </LinearLayout>

    <!--        btnTabCreation-->
    <LinearLayout
        android:id="@+id/btnTabCreation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!--            vLineTabHome-->
        <View
            android:id="@+id/vLineTabCreation"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginHorizontal="44dp"
            android:background="@color/blue_000D4C"
            android:visibility="invisible" />

        <!--            imvTabCreation-->
        <ImageView
            android:id="@+id/imvTabCreation"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginVertical="14dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_my_creation" />
    </LinearLayout>

    <!--        btnTabSetting-->
    <LinearLayout
        android:id="@+id/btnTabSetting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!--            vLineTabSetting-->
        <View
            android:id="@+id/vLineTabSetting"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginHorizontal="44dp"
            android:background="@color/blue_000D4C"
            android:visibility="invisible" />

        <!--            imvTabHome-->
        <ImageView
            android:id="@+id/imvTabSetting"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginVertical="14dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_settings" />
    </LinearLayout>

</LinearLayout>