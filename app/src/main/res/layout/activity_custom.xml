<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_F5F5F5"
    tools:context=".ui.custom.CustomActivity">

    <!--    btnDone-->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnDone"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="32dp"
        app:cardElevation="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#E6E6E6"
        app:strokeWidth="0.5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="12dp"
            android:fontFamily="@font/montserrat_medium"
            android:gravity="center"
            android:text="@string/done"
            android:textColor="@color/blue_000D4C"
            android:textSize="16sp"
            android:translationY="2dp" />
    </com.google.android.material.card.MaterialCardView>

    <!--    flExport-->
    <FrameLayout
        android:id="@+id/flExport"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintDimensionRatio="585:559"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnDone">

        <!--        imvClothes-->
        <ImageView
            android:id="@+id/imvClothes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY" />

        <!--        drawView-->
        <com.conchoback.haingon.core.custom.drawview.DrawView
            android:id="@+id/drawView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!--        rasmView-->
        <com.raed.rasmview.RasmView
            android:id="@+id/rasmView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/transparent" />
    </FrameLayout>

    <!--    rcvList-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/flExport"
        app:spanCount="5"
        tools:listitem="@layout/item_sticker" />

    <!--        lnlOption-->
    <LinearLayout
        android:id="@+id/lnlOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@+id/flExport">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_32_solid_gray_e6"
            android:orientation="horizontal"
            android:padding="4dp">

            <!--            btnChooseBrush-->
            <ImageView
                android:id="@+id/btnChooseBrush"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_1000_solid_white"
                android:src="@drawable/ic_brush" />

            <!--            btnEraser-->
            <ImageView
                android:id="@+id/btnEraser"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_eraser" />
        </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_32_solid_gray_e6">

            <!--                sbSize-->
            <com.conchoback.haingon.core.custom.seekbar.SizeSliderView
                android:id="@+id/sbSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginHorizontal="8dp" />
        </FrameLayout>
    </LinearLayout>

    <!--        colorPicker-->
    <com.conchoback.haingon.core.custom.colorpicker.ColorPickerView
        android:id="@+id/colorPicker"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="invisible"
        app:enableAlpha="true"
        app:enableBrightness="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lnlOption" />


</androidx.constraintlayout.widget.ConstraintLayout>