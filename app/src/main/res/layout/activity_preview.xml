<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_F5F5F5"
    tools:context=".ui.preview.PreviewActivity">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_24_solid_gray_e3"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutActionBar">

        <!--        tvTypeClothes-->
        <TextView
            android:id="@+id/tvTypeClothes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/montserrat_medium"
            android:text="Shirt"
            android:textColor="@color/blue_000D4C"
            android:textSize="16sp"
            android:translationY="1dp"
            app:layout_constraintBottom_toBottomOf="@+id/tvExtension"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvExtension" />

        <!--        tvExtension-->
        <TextView
            android:id="@+id/tvExtension"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_24_solid_gray_cc"
            android:fontFamily="@font/montserrat_medium"
            android:paddingHorizontal="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="1dp"
            android:text="PNG"
            android:textAllCaps="true"
            android:textColor="@color/gray_808080"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@+id/btnDownload"
            app:layout_constraintStart_toEndOf="@+id/tvTypeClothes"
            app:layout_constraintTop_toTopOf="@+id/btnDownload" />

        <!--        btnDownload-->
        <ImageView
            android:id="@+id/btnDownload"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!--        imvThumb-->
        <ImageView
            android:id="@+id/imvThumb"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="44dp"
            android:layout_marginVertical="24dp"
            android:scaleType="fitCenter"
            android:src="@drawable/test"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnDownload" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>