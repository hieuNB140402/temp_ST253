<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="-16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="-6dp"
        android:background="@drawable/bg_8_stroke_black_solid_white"
        app:layout_constraintBottom_toBottomOf="@+id/lnlBottomNavigation"
        app:layout_constraintEnd_toEndOf="@+id/lnlBottomNavigation"
        app:layout_constraintStart_toStartOf="@+id/lnlBottomNavigation"
        app:layout_constraintTop_toTopOf="@+id/lnlBottomNavigation" />

    <!--    lnlBottomNavigation-->
    <LinearLayout
        android:id="@+id/lnlBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!--            btnBrush-->
            <ImageView
                android:id="@+id/btnBrush"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_brush" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!--            btnSpeech-->
            <ImageView
                android:id="@+id/btnSpeech"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_speech" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!--            btnSticker-->
            <ImageView
                android:id="@+id/btnSticker"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_stiker" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!--            btnText-->
            <ImageView
                android:id="@+id/btnText"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_text" />
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>